{
  "schemaVersion": 1,
  "id": "musicplayer",
  "version": "${version}",
  "name": "Music Player",
  "description": "Play music from YouTube, SoundCloud, Bandcamp, local files, and HTTP streams inside Minecraft.",
  "authors": ["MusicPlayerMod"],
  "contact": {
    "issues": "https://github.com/example/musicplayer/issues",
    "sources": "https://github.com/example/musicplayer"
  },
  "license": "Apache-2.0",
  "icon": "assets/musicplayer/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.musicplayer.MusicPlayerMod"
    ]
  },
  "mixins": [
    "musicplayer.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.9",
    "fabric-api": "*",
    "fabric-command-api-v2": "*",
    "minecraft": "~1.21.11",
    "java": ">=21"
  }
}
